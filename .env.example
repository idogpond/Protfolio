# ─────────────────────────────────────────
# Docker Compose Root Environment Variables
# ─────────────────────────────────────────

# Database
DB_DATABASE=portfolio_db
DB_USERNAME=portfolio_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Admin account (seeded on startup). Change this before exposing the app
# publicly (e.g. via the Cloudflare Tunnel below) — the default is not secure.
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=password

# Cloudflare Tunnel
# 1. Create a named tunnel in Cloudflare Zero Trust → Networks → Tunnels
# 2. Set the tunnel service to http://nginx:80
# 3. Paste the tunnel token and your assigned <uuid>.cfargotunnel.com URL below
# 4. Update CORS_ALLOWED_ORIGINS to include the public URL
# 5. Start with: docker compose --profile tunnel up -d
TUNNEL_TOKEN=
PUBLIC_URL=
CORS_ALLOWED_ORIGINS=http://localhost:3000
